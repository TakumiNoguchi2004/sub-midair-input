# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Data: 各サブシステムの中身 (画像 / zip / 生成 index) は git 管理外。
# ディレクトリ構造だけ .gitkeep で残す。
/data/**
!/data/**/
!/data/**/.gitkeep

# Model cache
.cache/

# Vendored MediaPipe (JS/wasm/model) — ビルド時に fetch_mediapipe.py で取得する。
# git には載せず、Dockerfile / スクリプトで再取得する (CLIP モデルと同方針)。
/packages/web/src/midair_web/static/vendor/

# IDE / OS
.vscode/
.idea/
.DS_Store
